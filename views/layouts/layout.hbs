<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{titulo}} | KanbanPro</title>
  <link rel="stylesheet" href="/css/styles.css">
  <script>
    if (localStorage.getItem('modo') === 'oscuro') {
      document.documentElement.classList.add('dark-early');
    }
  </script>
</head>
<body>

  <nav class="navbar">
    <div class="navbar-brand">
      <a href="/">KanbanPro</a>
    </div>
    <ul class="navbar-links" id="navbar-links">
      <li><a href="/">Inicio</a></li>
      <li><a href="/dashboard">Dashboard</a></li>
      <li id="nav-login"><a href="/login">Iniciar Sesion</a></li>
      <li id="nav-register"><a href="/register" class="btn-nav">Registrarse</a></li>
      <li id="nav-usuario" style="display:none">
        <span id="nav-nombre" style="color:#ccc;font-size:0.9rem"></span>
      </li>
      <li id="nav-cerrar" style="display:none">
        <button class="btn-nav" onclick="cerrarSesion()" style="background:#e74c3c">Cerrar sesion</button>
      </li>
    </ul>
  </nav>

  <main class="main-content">
    {{{body}}}
  </main>

  <footer class="footer">
    <p>KanbanPro &copy; 2025 - Sprint 3 - MVP Funcional</p>
  </footer>

  <button class="btn-modo-flotante" onclick="toggleModo()" id="btnModo" title="Modo oscuro">
    🌙
  </button>

  <script>
    if (localStorage.getItem('modo') === 'oscuro') {
      document.body.classList.add('dark');
      document.getElementById('btnModo').textContent = '☀️';
    }

    function toggleModo() {
      var body = document.body;
      var html = document.documentElement;
      var btn = document.getElementById('btnModo');
      if (body.classList.contains('dark')) {
        body.classList.remove('dark');
        html.classList.remove('dark-early');
        btn.textContent = '🌙';
        localStorage.setItem('modo', 'claro');
      } else {
        body.classList.add('dark');
        html.classList.add('dark-early');
        btn.textContent = '☀️';
        localStorage.setItem('modo', 'oscuro');
      }
    }

    function cerrarSesion() {
      localStorage.removeItem('token');
      localStorage.removeItem('usuario');
      window.location.href = '/login';
    }

    // Actualizar navbar segun si hay sesion o no
    var token = localStorage.getItem('token');
    var usuario = JSON.parse(localStorage.getItem('usuario') || '{}');

    if (token && usuario.nombre) {
      document.getElementById('nav-login').style.display = 'none';
      document.getElementById('nav-register').style.display = 'none';
      document.getElementById('nav-usuario').style.display = 'block';
      document.getElementById('nav-cerrar').style.display = 'block';
      document.getElementById('nav-nombre').textContent = 'Hola, ' + usuario.nombre;
    }
  </script>

</body>
</html>