<section class="dashboard" id="dashboard">

  <div class="dashboard-header">
    <h1>📋 KanbanPro</h1>
  </div>

  <div id="contenido-tableros">
    <p class="cargando">Cargando tableros...</p>
  </div>

  <div class="nuevo-tablero-wrap">
    <button class="btn-nuevo-tablero" onclick="toggleFormulario('form-nuevo-tablero')">
      + Crear nuevo tablero
    </button>
    <form id="form-nuevo-tablero" class="form-nuevo-tablero oculto" onsubmit="crearTablero(event)">
      <input type="text" id="titulo-nuevo-tablero" placeholder="Nombre del tablero..." class="input-tarjeta" required>
      <div class="form-buttons">
        <button type="submit" class="btn btn-primary btn-sm">Crear</button>
        <button type="button" class="btn btn-cancel btn-sm" onclick="toggleFormulario('form-nuevo-tablero')">Cancelar</button>
      </div>
    </form>
  </div>

</section>

<script>
  var token = localStorage.getItem('token');
  var usuario = JSON.parse(localStorage.getItem('usuario') || '{}');

  if (!token) {
    window.location.href = '/login';
  }

  function getHeaders() {
    return {
      'Content-Type': 'application/json',
      'Authorization': 'Bearer ' + token
    };
  }

  function toggleFormulario(id) {
    var el = document.getElementById(id);
    el.classList.contains('oculto') ? el.classList.remove('oculto') : el.classList.add('oculto');
  }

  async function cargarTableros() {
    try {
      var response = await fetch('/api/tableros', { headers: getHeaders() });
      var tableros = await response.json();

      if (!response.ok) {
        window.location.href = '/login';
        return;
      }

      renderizarTableros(tableros);
    } catch (error) {
      console.error('Error al cargar tableros:', error);
    }
  }

  function renderizarTableros(tableros) {
    var contenedor = document.getElementById('contenido-tableros');

    if (tableros.length === 0) {
      contenedor.innerHTML = '<p class="cargando">No tenes tableros todavia. Crea uno abajo!</p>';
      return;
    }

    contenedor.innerHTML = tableros.map(function(tablero) {
      var listas = tablero.listas || [];
      return `
        <div class="tablero" id="tablero-${tablero.id}">
          <div class="tablero-header-row">
            <h2 class="tablero-titulo editable-inline" onclick="editarNombre(this, 'tablero', ${tablero.id})">${tablero.titulo}</h2>
            <button class="btn-icon-basura" onclick="eliminarTablero(${tablero.id})" title="Eliminar tablero">✕</button>
          </div>
          <div class="listas-container" id="listas-${tablero.id}">
            ${listas.map(function(lista) {
              return renderizarLista(lista, tablero.id);
            }).join('')}
            <div class="lista lista-nueva">
              <button class="btn-nueva-lista" onclick="toggleFormulario('nueva-lista-${tablero.id}')">+ Agregar columna</button>
              <form id="nueva-lista-${tablero.id}" class="form-nueva-tarjeta oculto" onsubmit="crearLista(event, ${tablero.id})">
                <input type="text" placeholder="Nombre de la columna..." class="input-tarjeta" required>
                <div class="form-buttons">
                  <button type="submit" class="btn btn-primary btn-sm">Crear</button>
                  <button type="button" class="btn btn-cancel btn-sm" onclick="toggleFormulario('nueva-lista-${tablero.id}')">Cancelar</button>
                </div>
              </form>
            </div>
          </div>
        </div>
      `;
    }).join('');
  }

  function renderizarLista(lista, tableroId) {
    var tarjetas = lista.tarjetas || [];
    return `
      <div class="lista" id="lista-${lista.id}">
        <div class="lista-header">
          <div class="lista-nombre-wrap">
            <h3 class="editable-inline" onclick="editarNombre(this, 'lista', ${lista.id}, ${tableroId})">${lista.titulo}</h3>
          </div>
          <div class="lista-header-right">
            <span class="lista-count">${tarjetas.length}</span>
            <button class="btn-eliminar-lista" onclick="eliminarLista(${lista.id}, ${tableroId})" title="Eliminar columna">✕</button>
          </div>
        </div>
        <div class="tarjetas-container" id="tarjetas-${lista.id}">
          ${tarjetas.map(function(tarjeta) {
            return renderizarTarjeta(tarjeta, lista.id);
          }).join('')}
        </div>
        <div class="agregar-tarjeta">
          <button class="btn-agregar" onclick="toggleFormulario('nueva-tarjeta-${lista.id}')">+ Agregar tarjeta</button>
          <form id="nueva-tarjeta-${lista.id}" class="form-nueva-tarjeta oculto" onsubmit="crearTarjeta(event, ${lista.id})">
            <input type="text" placeholder="Titulo de la tarjeta..." class="input-tarjeta" required>
            <textarea placeholder="Descripcion (opcional)" class="textarea-tarjeta" rows="2"></textarea>
            <div class="color-picker">
              <span class="color-label">Color:</span>
              <label class="color-opcion"><input type="radio" name="color-${lista.id}" value="#4f6ef7" checked><span class="color-circulo" style="background:#4f6ef7"></span></label>
              <label class="color-opcion"><input type="radio" name="color-${lista.id}" value="#22c55e"><span class="color-circulo" style="background:#22c55e"></span></label>
              <label class="color-opcion"><input type="radio" name="color-${lista.id}" value="#f59e0b"><span class="color-circulo" style="background:#f59e0b"></span></label>
              <label class="color-opcion"><input type="radio" name="color-${lista.id}" value="#e74c3c"><span class="color-circulo" style="background:#e74c3c"></span></label>
              <label class="color-opcion"><input type="radio" name="color-${lista.id}" value="#a855f7"><span class="color-circulo" style="background:#a855f7"></span></label>
            </div>
            <div class="form-buttons">
              <button type="submit" class="btn btn-primary btn-sm">Guardar</button>
              <button type="button" class="btn btn-cancel btn-sm" onclick="toggleFormulario('nueva-tarjeta-${lista.id}')">Cancelar</button>
            </div>
          </form>
        </div>
      </div>
    `;
  }

  function renderizarTarjeta(tarjeta, listaId) {
    return `
      <div class="tarjeta" style="border-left-color: ${tarjeta.color || '#4f6ef7'}" id="tarjeta-${tarjeta.id}">
        <div class="tarjeta-header">
          <p class="tarjeta-titulo">${tarjeta.titulo}</p>
          <button class="btn-eliminar" onclick="eliminarTarjeta(${tarjeta.id}, ${listaId})">✕</button>
        </div>
        ${tarjeta.descripcion ? `<p class="tarjeta-desc">${tarjeta.descripcion}</p>` : ''}
      </div>
    `;
  }

  async function crearTablero(e) {
    e.preventDefault();
    var titulo = document.getElementById('titulo-nuevo-tablero').value;
    var response = await fetch('/api/tableros', {
      method: 'POST',
      headers: getHeaders(),
      body: JSON.stringify({ titulo })
    });
    if (response.ok) {
      document.getElementById('titulo-nuevo-tablero').value = '';
      toggleFormulario('form-nuevo-tablero');
      cargarTableros();
    }
  }

  async function eliminarTablero(id) {
    if (!confirm('Seguro que queres eliminar este tablero?')) return;
    var response = await fetch('/api/tableros/' + id, {
      method: 'DELETE',
      headers: getHeaders()
    });
    if (response.ok) cargarTableros();
  }

  async function crearLista(e, tableroId) {
    e.preventDefault();
    var input = e.target.querySelector('input[type="text"]');
    var titulo = input.value.trim();
    if (!titulo) return;
    var response = await fetch('/api/tableros/' + tableroId + '/listas', {
      method: 'POST',
      headers: getHeaders(),
      body: JSON.stringify({ titulo })
    });
    if (response.ok) {
      input.value = '';
      toggleFormulario('nueva-lista-' + tableroId);
      cargarTableros();
    }
  }

  async function eliminarLista(listaId, tableroId) {
    if (!confirm('Seguro que queres eliminar esta columna?')) return;
    var response = await fetch('/api/tableros/' + tableroId + '/listas/' + listaId, {
      method: 'DELETE',
      headers: getHeaders()
    });
    if (response.ok) cargarTableros();
  }

  async function crearTarjeta(e, listaId) {
    e.preventDefault();
    var titulo = e.target.querySelector('input[type="text"]').value;
    var descripcion = e.target.querySelector('textarea').value;
    var colorSeleccionado = e.target.querySelector('input[name="color-' + listaId + '"]:checked');
    var color = colorSeleccionado ? colorSeleccionado.value : '#4f6ef7';
    var response = await fetch('/api/listas/' + listaId + '/tarjetas', {
      method: 'POST',
      headers: getHeaders(),
      body: JSON.stringify({ titulo, descripcion, color })
    });
    if (response.ok) {
      toggleFormulario('nueva-tarjeta-' + listaId);
      cargarTableros();
    }
  }

  async function eliminarTarjeta(tarjetaId, listaId) {
    var response = await fetch('/api/listas/' + listaId + '/tarjetas/' + tarjetaId, {
      method: 'DELETE',
      headers: getHeaders()
    });
    if (response.ok) cargarTableros();
  }

  function editarNombre(elemento, tipo, id, tableroId) {
    var textoActual = elemento.textContent.trim();
    var input = document.createElement('input');
    input.type = 'text';
    input.value = textoActual;
    input.className = 'input-inline';
    elemento.replaceWith(input);
    input.focus();
    input.select();

    async function guardar() {
      var nuevoNombre = input.value.trim();
      if (!nuevoNombre || nuevoNombre === textoActual) {
        input.replaceWith(elemento);
        return;
      }
      var url = tipo === 'tablero'
        ? '/api/tableros/' + id
        : '/api/tableros/' + tableroId + '/listas/' + id;
      await fetch(url, {
        method: 'PUT',
        headers: getHeaders(),
        body: JSON.stringify({ titulo: nuevoNombre })
      });
      cargarTableros();
    }

    input.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') guardar();
      if (e.key === 'Escape') input.replaceWith(elemento);
    });
    input.addEventListener('blur', guardar);
  }

  cargarTableros();
</script>